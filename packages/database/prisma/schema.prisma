// This is your Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema
// Auth.js v5 compatible schema — @auth/prisma-adapter required field shapes

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum ServiceCategory {
  HAIRCUT
  COMBO
  PREMIUM
  VIP
  COLORIMETRIA
  KIDS
}

// ─── Auth.js Models ──────────────────────────────────────────────────────────
// Field shapes are required by @auth/prisma-adapter — do NOT rename them.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CLIENT)

  // Extended profile fields
  phone                  String?
  onboardingCompletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  timeBlocks   TimeBlock[]
  appointments Appointment[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ─── Domain Models ────────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  durationMin Int
  price       Int      // COP whole integers
  active      Boolean         @default(true)
  category    ServiceCategory @default(HAIRCUT)
  priceNote   String?
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  appointments Appointment[]

  @@map("services")
}

model AdminAvailability {
  id          String  @id @default(cuid())
  dayOfWeek   Int     // 0=Sunday, 6=Saturday
  startTime   String  // "HH:mm"
  endTime     String  // "HH:mm"
  slotMinutes Int     @default(30)
  active      Boolean @default(true)

  @@unique([dayOfWeek])
  @@map("admin_availability")
}

model TimeBlock {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  startTime String   // "HH:mm"
  endTime   String   // "HH:mm"
  reason    String?
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User @relation(fields: [createdBy], references: [id])

  @@map("time_blocks")
}

model Appointment {
  id                 String            @id @default(cuid())
  userId             String
  serviceId          String
  startAt            DateTime
  endAt              DateTime
  status             AppointmentStatus @default(PENDING)
  notes              String?
  cancellationReason String?
  reminderSentAt     DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@index([startAt, status])
  @@index([userId, status])
  @@map("appointments")
}
