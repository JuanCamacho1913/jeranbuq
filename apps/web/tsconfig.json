{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@barberia-jeranbuq/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "rootDir": ".",
    "incremental": true,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "src/**/*",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
