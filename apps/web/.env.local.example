# Database
# Local Docker Postgres (see docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/barberia_jeranbuq"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/barberia_jeranbuq"

# Auth.js v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email (Resend) - reserved for future use
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"
ADMIN_NOTIFICATION_EMAIL="admin@yourdomain.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APPOINTMENT_CANCEL_HOURS="2"
DEFAULT_PHONE_COUNTRY_CODE="+57"

# Barber Access
# Secret code required for barbers to claim the ADMIN role at first login
BARBER_SECRET_CODE=""
