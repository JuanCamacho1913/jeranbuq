# Database — Neon pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://..."

# Database — Neon direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://..."

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Auth.js — full production URL (e.g. https://tudominio.com)
AUTH_URL=""

# Auth.js — required on Vercel
AUTH_TRUST_HOST=true

# Google OAuth — from Google Cloud Console
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend — transactional emails
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Notifications — barber's email for new booking alerts
ADMIN_NOTIFICATION_EMAIL=""

# Vercel Cron — random secret to protect the cron endpoint
CRON_SECRET=""

# Sentry — from Sentry project settings > Client Keys
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry — optional, enables source map upload on build
# SENTRY_AUTH_TOKEN=""
